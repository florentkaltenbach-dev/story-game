# The Ceremony — Keeper Service Environment
# Read by dotenv/config at startup.

# Anthropic API key (leave commented for mock mode)
# ANTHROPIC_API_KEY=sk-ant-...

# Model and rate limits
KEEPER_MODEL=claude-haiku-4-5-20251001
KEEPER_MAX_TOKENS_PER_RESPONSE=1024
KEEPER_MAX_REQUESTS_PER_SESSION=100
KEEPER_MAX_REQUESTS_PER_MINUTE=10
KEEPER_PORT=3005

# Must match KEEPER_SHARED_SECRET in root .env
KEEPER_SHARED_SECRET=
