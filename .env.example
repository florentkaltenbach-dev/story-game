# The Ceremony — Root Environment
# Generated by ./setup.sh — do not commit the real .env file.

# HMAC signing key for auth tokens (32 bytes hex)
CEREMONY_TOKEN_SECRET=

# MC login password (16 bytes hex)
MC_SECRET=

# Shared secret between web and keeper-service (32 bytes hex)
KEEPER_SHARED_SECRET=

# "mock" = no API calls (default), "remote" = real Claude API
KEEPER_BACKEND=mock

# Dev-only: set to MC_SECRET value to show autofill button on login (never set in production)
# NEXT_PUBLIC_DEV_MC_SECRET=
