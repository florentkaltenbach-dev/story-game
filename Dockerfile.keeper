FROM node:22-alpine

WORKDIR /app/keeper-service

# Install dependencies
COPY keeper-service/package.json keeper-service/package-lock.json* ./
RUN npm ci

# Copy source
COPY keeper-service/ ./

# Create directories for runtime data
RUN mkdir -p /app/memory /app/config

EXPOSE 3005
ENV KEEPER_PORT=3005

CMD ["npx", "tsx", "server.ts"]
